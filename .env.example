# Backend service
ALLOWED_ORIGINS=https://edstratumlabs.ai,https://www.edstratumlabs.ai,https://edstratumlabs.pages.dev,http://localhost:5173
CONFIDENCE_THRESHOLD=0.55
CALENDLY_URL=
KNOWLEDGE_BASE_DIR=data/knowledge_base
ESCALATION_LOG_DIR=data/escalations

# Generative LLM integration: WRITER Palmyra is the default chat provider.
# Set this in your local environment or Railway; do not commit live keys.
WRITER_API_KEY=
LLM_PROVIDER=writer
LLM_BASE_URL=https://api.writer.com/v1/chat/completions
LLM_MODEL=palmyra-x5
LLM_API_KEY=

# Optional OpenAI embeddings or explicit OpenAI chat override
OPENAI_API_KEY=
# Leave blank for deterministic hash embeddings.
# Set EMBEDDING_PROVIDER=openai only when OPENAI_API_KEY is configured for embeddings.
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIR=
PINECONE_API_KEY=
PINECONE_INDEX=stratum-kb
PINECONE_NAMESPACE=
# COHERE_API_KEY present -> Cohere rerank; absent -> heuristic rerank.
RERANKER_PROVIDER=
RERANKER_MODEL=rerank-v4.0-fast

# Production persistence
DATABASE_URL=

# Optional managed reranking
COHERE_API_KEY=

# Optional escalation email
RESEND_API_KEY=
ESCALATION_EMAIL_TO=
ESCALATION_EMAIL_FROM=
# Legacy aliases are still accepted by the app for older Railway projects:
JEFFREY_EMAIL=
RESEND_FROM_EMAIL=

# Optional browser voice playback proxy. Keep the API key server-side only.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional: override the ElevenLabs API base URL. Defaults to the US regional
# endpoint (https://api.us.elevenlabs.io/v1) for lower latency, ported from
# Project-Tango. The /v1 suffix is auto-appended if missing.
ELEVENLABS_BASE_URL=https://api.us.elevenlabs.io/v1

# Cloudflare Pages connection, used by scripts only
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=
CLOUDFLARE_PAGES_PROJECT=edstratumlabs
STRATUM_BACKEND_URL=
