# Backend service
ALLOWED_ORIGINS=https://edstratumlabs.ai,https://www.edstratumlabs.ai,https://edstratumlabs.pages.dev,http://localhost:5173
CONFIDENCE_THRESHOLD=0.55
CALENDLY_URL=
KNOWLEDGE_BASE_DIR=data/knowledge_base
ESCALATION_LOG_DIR=data/escalations

# Optional LLM integration
OPENAI_API_KEY=
LLM_MODEL=gpt-4o
# Leave provider selectors blank for auto mode:
# OPENAI_API_KEY present -> OpenAI embeddings; absent -> deterministic hash.
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIR=
# COHERE_API_KEY present -> Cohere rerank; absent -> heuristic rerank.
RERANKER_PROVIDER=
RERANKER_MODEL=rerank-v4.0-fast

# Optional persistence and managed retrieval
DATABASE_URL=
PINECONE_API_KEY=
PINECONE_ENV=
PINECONE_INDEX=stratum-kb
QDRANT_URL=
QDRANT_API_KEY=
COHERE_API_KEY=

# Optional escalation email
RESEND_API_KEY=
JEFFREY_EMAIL=
RESEND_FROM_EMAIL=

# Cloudflare Pages connection, used by scripts only
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_KEY=
CLOUDFLARE_EMAIL=
CLOUDFLARE_PAGES_PROJECT=edstratumlabs
STRATUM_BACKEND_URL=
